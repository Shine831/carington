"use client";

import { Activity, ShieldAlert, ShieldCheck, Cpu, Server, CheckCircle2, Clock, AlertTriangle, ArrowRight, LogOut, FileText, Star, X, MessageSquare, Lock, Key, Users, Eye, EyeOff, RefreshCw } from "lucide-react";
import Link from "next/link";
import { useRouter } from "next/navigation";
import { motion, AnimatePresence } from "framer-motion";
import { FadeUp, StaggerContainer, StaggerItem, FadeIn } from "@/components/ui/Motion";
import { AuraGradient } from "@/components/ui/AuraGradient";
import { useI18n } from "@/context/LanguageContext";
import { useState, useEffect, useCallback } from "react";
import { useAuth } from "@/hooks/useAuth";
import { auth } from "@/lib/firebase/config";
import { updateProfile, verifyBeforeUpdateEmail, EmailAuthProvider, reauthenticateWithCredential, sendPasswordResetEmail } from "firebase/auth";
import { updateUserDoc, updateReview, getReviewsByUserId, getBookings, setUserPin, getUserById, deleteBooking, createReview } from "@/lib/firebase/db";
import { logoutUser } from "@/lib/firebase/auth";

const STATUS_MAP = {
  fr: {
    PENDING:   { label: "En attente", cls: "bg-amber-500/10 text-amber-500 border-amber-500/20" },
    ACTIVE:    { label: "En cours",   cls: "bg-blue-500/10 text-blue-500 border-blue-500/20" },
    COMPLETED: { label: "Terminé",    cls: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" },
    REJECTED:  { label: "Rejeté",     cls: "bg-red-500/10 text-red-500 border-red-500/20" },
  },
  en: {
    PENDING:   { label: "Pending", cls: "bg-amber-500/10 text-amber-500 border-amber-500/20" },
    ACTIVE:    { label: "Active",   cls: "bg-blue-500/10 text-blue-500 border-blue-500/20" },
    COMPLETED: { label: "Completed",    cls: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" },
    REJECTED:  { label: "Rejected",     cls: "bg-red-500/10 text-red-500 border-red-500/20" },
  }
};

export default function DashboardPage() {
  const { t, language } = useI18n();
  const router = useRouter();
  const { user, loading: authLoading } = useAuth();

  const [bookings, setBookings] = useState<any[]>([]);
  const [userReviews, setUserReviews] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);

  const [showReviewModal, setShowReviewModal] = useState(false);
  const [reviewRating, setReviewRating] = useState(0);
  const [hoverRating, setHoverRating] = useState(0);
  const [reviewComment, setReviewComment] = useState("");
  const [isSubmittingReview, setIsSubmittingReview] = useState(false);
  const [editingReview, setEditingReview] = useState<any>(null);

  const [checkingPin, setCheckingPin] = useState(true);
  const [hasPinConfigured, setHasPinConfigured] = useState(false);
  const [isPinVerified, setIsPinVerified] = useState(false);
  const [pinInput, setPinInput] = useState("");
  const [pinError, setPinError] = useState(false);

  const [activeTab, setActiveTab] = useState<"projects" | "reviews" | "profile">("projects");
  const [profileForm, setProfileForm] = useState({ name: "", email: "", currentPassword: "", error: "", success: "" });
  const [isUpdatingProfile, setIsUpdatingProfile] = useState(false);

  const firstName = user?.displayName ? user.displayName.split(" ")[0] : "Client";

  const fetchData = useCallback(async () => {
    if (!user) return;
    setLoading(true);
    try {
      const [bks, rvs] = await Promise.all([getBookings(user.uid), getReviewsByUserId(user.uid)]);
      setBookings(bks);
      setUserReviews(rvs);
    } catch (err) { console.error(err); }
    finally { setLoading(false); }
  }, [user]);

  useEffect(() => {
    if (user) {
      if (typeof window !== "undefined" && sessionStorage.getItem("client_pin_verified") === "true") {
        setIsPinVerified(true); setCheckingPin(false); fetchData(); return;
      }
      getUserById(user.uid).then(userData => {
        setHasPinConfigured(!!userData?.pin);
        setProfileForm({ name: user.displayName || "", email: user.email || "", currentPassword: "", error: "", success: "" });
        setCheckingPin(false);
      });
      fetchData();
    }
  }, [user, fetchData]);

  async function hashPin(pin: string) {
    const enc = new TextEncoder().encode(pin);
    const hashBuffer = await crypto.subtle.digest('SHA-256', enc);
    return Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  const handlePinSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!user || pinInput.length < 4) return;
    const hashed = await hashPin(pinInput);
    if (!hasPinConfigured) {
      await setUserPin(user.uid, hashed); setHasPinConfigured(true); setIsPinVerified(true);
      sessionStorage.setItem("client_pin_verified", "true");
    } else {
      const userData = await getUserById(user.uid);
      if (userData?.pin === hashed) {
        setIsPinVerified(true); sessionStorage.setItem("client_pin_verified", "true");
      } else { setPinError(true); setPinInput(""); }
    }
  };

  const handleDeleteRequest = async (id: string) => {
    if (confirm("Annuler cette demande ?")) { await deleteBooking(id); fetchData(); }
  };

  const handleProfileUpdate = async (e: React.FormEvent) => {
    e.preventDefault(); if (!user) return;
    setIsUpdatingProfile(true); setProfileForm(p => ({ ...p, success: "", error: "" }));
    try {
      if (profileForm.name !== user.displayName) {
        await updateProfile(user, { displayName: profileForm.name });
        await updateUserDoc(user.uid, { displayName: profileForm.name });
      }
      setProfileForm(p => ({ ...p, success: "Profil mis à jour !" }));
    } catch (err: any) { setProfileForm(p => ({ ...p, error: err.message })); }
    finally { setIsUpdatingProfile(false); }
  };

  const handleSubmitReview = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!user || reviewRating === 0) return;
    setIsSubmittingReview(true);
    try {
      if (editingReview) {
        await updateReview(editingReview.id, { rating: reviewRating, comment: reviewComment });
      } else {
        await createReview(user.uid, user.displayName || "Client", "Général", reviewRating, reviewComment);
      }
      setShowReviewModal(false); setEditingReview(null); setReviewRating(0); setReviewComment(""); fetchData();
    } catch (err) { console.error(err); }
    finally { setIsSubmittingReview(false); }
  };

  const handleDeleteReview = async (id: string) => {
    if (confirm("Supprimer ce témoignage ?")) {
      const { deleteReview } = await import("@/lib/firebase/db");
      await deleteReview(id); fetchData();
    }
  };

  if (authLoading || !user || checkingPin) {
    return (
      <div className="min-h-screen bg-[var(--off-white)] flex items-center justify-center">
        <div className="w-12 h-12 rounded-2xl flex items-center justify-center border border-red-100 bg-[var(--red-light)] mb-6 shadow-sm"><Activity className="w-6 h-6 text-[var(--red)] animate-spin" /></div>
      </div>
    );
  }

  if (!isPinVerified) {
    return (
      <div className="min-h-[100svh] bg-[var(--off-white)] flex flex-col items-center justify-center p-4 relative overflow-hidden">
        <AuraGradient color="var(--red)" className="w-[800px] h-[800px] opacity-[0.03]" />
        <motion.div initial={{ opacity: 0, scale: 0.98 }} animate={{ opacity: 1, scale: 1 }} className="w-full max-w-sm relative z-10">
          <div className="bg-white/80 backdrop-blur-3xl border border-[var(--border)] p-10 rounded-[2.5rem] shadow-xl flex flex-col items-center text-center">
            <div className="w-16 h-16 rounded-2xl bg-[var(--red-light)] text-[var(--red)] flex items-center justify-center mb-6 shadow-sm border border-red-100"><Lock className="w-8 h-8" /></div>
            <h1 className="text-2xl font-black text-[var(--charcoal)] tracking-tight mb-2">Espace Sécurisé</h1>
            <p className="text-[var(--slate)] text-[11px] mb-8 leading-relaxed">Veuillez entrer votre Code PIN pour accéder à votre tableau de bord.</p>
            <form onSubmit={handlePinSubmit} className="w-full space-y-6">
              <input type="password" value={pinInput} onChange={e=>{setPinInput(e.target.value); setPinError(false);}} placeholder="••••" maxLength={4} autoFocus className={`w-full bg-[var(--off-white)] border ${pinError ? 'border-red-500':'border-[var(--border)] focus:border-[var(--red)]'} p-4 rounded-2xl text-center text-2xl font-black tracking-[1em] outline-none transition-all`} />
              <button type="submit" disabled={pinInput.length < 4} className="w-full py-4 bg-[var(--red)] rounded-2xl text-white font-black text-[11px] uppercase tracking-widest shadow-lg transition-all">Déverrouiller</button>
            </form>
          </div>
        </motion.div>
      </div>
    );
  }

  return (
    <div className="min-h-[100svh] pt-32 pb-40 bg-[var(--off-white)] relative overflow-hidden">
      <AuraGradient color="var(--red)" className="top-0 right-0 w-[800px] h-[800px] opacity-[0.04]" />

      <div className="container-xl max-w-6xl relative z-10">
        <div className="flex flex-col md:flex-row md:items-center justify-between mb-16 gap-8 border-b border-slate-200 pb-12">
          <FadeUp>
            <div className="flex items-center gap-3 mb-6"><div className="h-2 w-8 bg-[var(--red)] rounded-full shadow-md" /><span className="text-[10px] font-black text-[var(--red)] uppercase tracking-widest">{t.dashboard.title}</span></div>
            <h1 className="text-4xl lg:text-6xl font-black text-[var(--charcoal)] tracking-tighter mb-4 leading-tight">{t.dashboard.welcome} <span className="text-[var(--red)]">{firstName}.</span></h1>
            <p className="text-sm font-medium text-[var(--slate)] max-w-lg leading-relaxed">Suivez l{"'"}avancement de vos demandes et gérez vos actifs numériques en toute sécurité.</p>
          </FadeUp>
          <FadeIn delay={0.3}>
            <div className="bg-white/80 backdrop-blur-md border border-[var(--border)] px-8 py-6 rounded-[2.5rem] shadow-sm flex items-center gap-4">
              <ShieldCheck className="w-6 h-6 text-[var(--red)]" /><div className="flex flex-col"><span className="text-[10px] font-black uppercase tracking-widest">Compte Vérifié</span><span className="text-[9px] text-[var(--muted)] font-bold uppercase tracking-widest italic">Actif • SLA Premium</span></div>
            </div>
          </FadeIn>
        </div>

        <div className="flex gap-2 p-1.5 bg-white/60 backdrop-blur-xl rounded-full border border-white/40 mb-16 w-fit mx-auto md:mx-0 shadow-lg">
          {[
            { id: "projects", label: t.dashboard.tabs.projects, icon: FileText },
            { id: "reviews", label: t.dashboard.tabs.reviews, icon: Star },
            { id: "profile", label: t.dashboard.tabs.profile, icon: Users }
          ].map((tab) => (
            <button key={tab.id} onClick={() => setActiveTab(tab.id as any)} className={`flex items-center gap-3 px-8 py-3.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all duration-500 relative group ${activeTab === tab.id ? "text-white" : "text-[var(--muted)] hover:text-[var(--charcoal)]"}`}>
              {activeTab === tab.id && <motion.div layoutId="clientTabGlow" className="absolute inset-0 bg-[var(--red)] shadow-lg -z-0" transition={{ type: "spring", duration: 0.6 }} />}
              <tab.icon className="w-4 h-4 relative z-10" /><span className="hidden sm:inline relative z-10">{tab.label}</span>
            </button>
          ))}
        </div>

        {activeTab === "projects" && (
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            {loading ? (
              <div className="col-span-full py-20 flex justify-center"><RefreshCw className="w-10 h-10 text-[var(--red)] animate-spin" /></div>
            ) : bookings.length === 0 ? (
              <div className="col-span-full py-24 text-center rounded-[3rem] bg-white border border-dashed border-slate-200 font-black text-xs uppercase tracking-widest text-[var(--muted)]">{t.dashboard.projects.empty}</div>
            ) : bookings.map((req) => {
              const mapObj = STATUS_MAP[language as "fr" | "en"][req.status as keyof typeof STATUS_MAP["fr"]] || STATUS_MAP[language as "fr" | "en"].PENDING;
              return (
                <motion.div key={req.id} whileHover={{ y: -5 }} className="bento-item p-8 glass-morphism spatial-ui-layer relative group">
                  <div className="absolute top-0 left-0 w-full h-1" style={{ backgroundColor: req.status === "COMPLETED" ? "#10B981" : req.status === "ACTIVE" ? "#3B82F6" : "var(--red)" }} />
                  <div className="space-y-6">
                    <div className="flex justify-between items-start">
                      <div className="space-y-1"><span className="text-[9px] font-black text-[var(--muted)] uppercase">ID #{req.id.slice(0, 8).toUpperCase()}</span><h3 className="display-sm text-[var(--charcoal)] line-clamp-2 uppercase">{req.serviceId}</h3></div>
                      <span className={`px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border shadow-sm ${mapObj.cls}`}>{mapObj.label}</span>
                    </div>
                    <div className="p-5 bg-[var(--off-white)] rounded-2xl border border-slate-100"><p className="text-[8px] font-black text-[var(--muted)] uppercase mb-1">Date de demande</p><p className="text-xs font-bold">{req.createdAt ? new Date(req.createdAt.seconds*1000).toLocaleDateString() : 'N/A'}</p></div>
                    {req.adminNote && <div className="p-5 bg-red-50/50 border border-red-100 rounded-2xl text-[11px] text-[var(--slate)] leading-relaxed italic">"{req.adminNote}"</div>}
                    {req.status === "PENDING" && <button onClick={() => handleDeleteRequest(req.id)} className="w-full py-4 bg-white border border-slate-200 rounded-full text-[9px] font-black uppercase text-red-500 hover:bg-red-50 transition-all shadow-sm">Annuler la demande</button>}
                  </div>
                </motion.div>
              );
            })}
          </div>
        )}

        {activeTab === "reviews" && (
          <div className="space-y-12 mb-16">
            <div className="flex justify-between items-center"><h2 className="text-2xl font-black text-[var(--charcoal)] tracking-tight">Mes Témoignages</h2><button onClick={()=>{setEditingReview(null); setReviewRating(0); setReviewComment(""); setShowReviewModal(true);}} className="btn btn-red px-6 py-3 text-[10px] uppercase font-black tracking-widest shadow-md">+ Nouveau</button></div>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-8">
              {userReviews.length === 0 ? (
                <div className="col-span-full py-20 text-center rounded-[3rem] bg-white border border-dashed border-slate-200 font-black text-xs text-[var(--muted)]">Aucun témoignage envoyé.</div>
              ) : userReviews.map((rev) => (
                <motion.div key={rev.id} whileHover={{ y: -5 }} className="bento-item p-8 glass-morphism relative overflow-hidden flex flex-col justify-between">
                  <div className="absolute top-0 left-0 w-full h-1 bg-amber-400" />
                  <div>
                    <div className="flex justify-between mb-4">
                      <div className="flex gap-0.5">{[1,2,3,4,5].map(s=><Star key={s} className={`w-3 h-3 ${s<=rev.rating ? 'fill-amber-400 text-amber-400':'text-slate-200'}`} />)}</div>
                      <span className="text-[9px] font-black text-[var(--muted)] uppercase">{rev.createdAt ? new Date(rev.createdAt.seconds*1000).toLocaleDateString() : 'N/A'}</span>
                    </div>
                    <p className="text-sm font-medium text-[var(--slate)] leading-relaxed mb-6 italic">"{rev.comment}"</p>
                  </div>
                  <div className="flex gap-4 pt-6 border-t border-slate-100">
                    <button onClick={()=>{setEditingReview(rev); setReviewRating(rev.rating); setReviewComment(rev.comment); setShowReviewModal(true);}} className="text-[9px] font-black uppercase text-[var(--muted)] hover:text-[var(--charcoal)] transition-all">Éditer</button>
                    <button onClick={()=>handleDeleteReview(rev.id)} className="text-[9px] font-black uppercase text-red-500 hover:text-red-700 transition-all">Supprimer</button>
                  </div>
                </motion.div>
              ))}
            </div>
          </div>
        )}

        {activeTab === "profile" && (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
            <div className="p-10 bg-white border border-[var(--border)] rounded-[3rem] flex flex-col items-center text-center shadow-lg relative overflow-hidden">
               <div className="w-24 h-24 rounded-full bg-[var(--red)] flex items-center justify-center text-3xl font-black text-white mb-6 shadow-xl">{(user.displayName || "C")[0]}</div>
               <h3 className="text-2xl font-black text-[var(--charcoal)] tracking-tight">{user.displayName}</h3>
               <p className="text-xs font-bold text-[var(--muted)] mt-1">{user.email}</p>
            </div>
            <div className="lg:col-span-2 p-10 bg-white border border-[var(--border)] rounded-[3rem] shadow-lg relative overflow-hidden">
               <AuraGradient color="var(--red)" className="bottom-[-10%] right-[-10%] w-64 h-64 opacity-[0.03]" />
               <h3 className="text-2xl font-black text-[var(--charcoal)] tracking-tighter mb-10">Informations du compte</h3>
               <form onSubmit={handleProfileUpdate} className="space-y-8">
                 <div className="grid grid-cols-1 sm:grid-cols-2 gap-8">
                   <div className="space-y-2"><label className="text-[10px] font-black uppercase text-[var(--muted)]">Nom Complet</label><input type="text" value={profileForm.name} onChange={e=>setProfileForm({...profileForm, name: e.target.value})} className="w-full bg-[var(--off-white)] border border-slate-200 p-5 rounded-2xl text-sm font-bold focus:border-[var(--red)] outline-none" /></div>
                   <div className="space-y-2"><label className="text-[10px] font-black uppercase text-[var(--muted)]">Email</label><input type="email" value={profileForm.email} disabled className="w-full bg-slate-50 border border-slate-200 p-5 rounded-2xl text-sm font-bold opacity-60" /></div>
                 </div>
                 {profileForm.success && <p className="text-[10px] font-black text-emerald-600 uppercase">{profileForm.success}</p>}
                 <button type="submit" disabled={isUpdatingProfile} className="px-10 py-5 bg-[var(--charcoal)] text-white rounded-full font-black text-[11px] uppercase tracking-widest shadow-xl">{isUpdatingProfile ? "Action..." : "Sauvegarder"}</button>
               </form>
            </div>
          </div>
        )}

        <StaggerContainer className="grid md:grid-cols-2 gap-8">
          <StaggerItem>
            <div className="p-10 border border-slate-200 rounded-[3rem] bg-white shadow-sm flex flex-col sm:flex-row gap-8 group hover:border-red-200 transition-all">
              <div className="w-16 h-16 rounded-2xl bg-red-50 flex items-center justify-center group-hover:bg-[var(--red)] transition-all"><AlertTriangle className="w-8 h-8 text-[var(--red)] group-hover:text-white" /></div>
              <div className="flex-1">
                <h3 className="text-2xl font-black tracking-tight mb-2">Support Prioritaire</h3>
                <p className="text-sm text-[var(--slate)] font-medium mb-6 leading-relaxed">Intervention garantie en moins de 120min pour tous vos actifs.</p>
                <Link href="/contact" className="inline-flex items-center gap-3 px-6 py-4 rounded-full bg-[var(--off-white)] border border-slate-200 text-[10px] font-black uppercase hover:bg-white hover:border-red-200 transition-all shadow-sm">Ouvrir un ticket <ArrowRight className="w-4 h-4 text-[var(--red)]" /></Link>
              </div>
            </div>
          </StaggerItem>
          <StaggerItem>
            <div className="p-10 border border-slate-200 rounded-[3rem] bg-white shadow-sm flex flex-col sm:flex-row gap-8 group hover:border-emerald-200 transition-all">
              <div className="w-16 h-16 rounded-2xl bg-emerald-50 flex items-center justify-center group-hover:bg-emerald-500 transition-all"><Cpu className="w-8 h-8 text-emerald-500 group-hover:text-white" /></div>
              <div className="flex-1">
                <h3 className="text-2xl font-black tracking-tight mb-2">Cloud & Infra</h3>
                <p className="text-sm text-[var(--slate)] font-medium mb-6 leading-relaxed">Surveillance proactive de votre infrastructure 24/7.</p>
                <Link href="/services" className="inline-flex items-center gap-3 px-6 py-4 rounded-full bg-[var(--off-white)] border border-slate-200 text-[10px] font-black uppercase hover:bg-white hover:border-emerald-200 transition-all shadow-sm">Explorer le catalogue <ArrowRight className="w-4 h-4 text-emerald-500" /></Link>
              </div>
            </div>
          </StaggerItem>
        </StaggerContainer>
      </div>

      <AnimatePresence>
        {showReviewModal && (
          <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} onClick={()=>setShowReviewModal(false)} className="absolute inset-0 bg-black/60 backdrop-blur-md" />
            <motion.div initial={{ scale: 0.95, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.95, opacity: 0 }} className="relative w-full max-w-lg bg-white border border-[var(--border)] shadow-2xl rounded-[3rem] p-10 z-10 overflow-hidden">
               <AuraGradient color="var(--red)" className="top-0 right-0 w-64 h-64 opacity-[0.05]" />
               <button onClick={()=>setShowReviewModal(false)} className="absolute top-8 right-8 p-2 text-[var(--muted)] hover:text-[var(--charcoal)]"><X className="w-6 h-6" /></button>
               <div className="mb-8"><div className="w-16 h-16 rounded-2xl bg-red-50 flex items-center justify-center mb-6"><Star className="w-8 h-8 text-[var(--red)] fill-current" /></div><h3 className="text-2xl font-black text-[var(--charcoal)]">{editingReview ? "Modifier mon avis" : "Laisser un témoignage"}</h3><p className="text-sm font-medium text-[var(--slate)] mt-2">Votre retour d{"'"}expérience nous est précieux.</p></div>
               <form onSubmit={handleSubmitReview} className="space-y-8 relative z-10">
                 <div>
                   <label className="block text-[10px] font-black uppercase text-[var(--muted)] mb-4">Votre note</label>
                   <div className="flex gap-2">{[1,2,3,4,5].map(star=>(<button key={star} type="button" onClick={()=>setReviewRating(star)} onMouseEnter={()=>setHoverRating(star)} onMouseLeave={()=>setHoverRating(0)} className="transition-transform hover:scale-110 active:scale-95"><Star className={`w-10 h-10 transition-colors ${(hoverRating||reviewRating)>=star ? 'text-amber-400 fill-amber-400 drop-shadow-md':'text-slate-100'}`} /></button>))}</div>
                 </div>
                 <div>
                   <label className="block text-[10px] font-black uppercase text-[var(--muted)] mb-4">Votre commentaire</label>
                   <div className="relative"><MessageSquare className="absolute top-5 left-5 w-5 h-5 text-[var(--muted)]" /><textarea required value={reviewComment} onChange={e=>setReviewComment(e.target.value)} placeholder="Partagez votre expérience..." className="w-full h-32 pl-14 pr-5 py-5 bg-[var(--off-white)] border border-slate-200 rounded-3xl text-[var(--charcoal)] outline-none focus:border-[var(--red)] transition-all resize-none shadow-inner" /></div>
                 </div>
                 <button type="submit" disabled={isSubmittingReview || reviewRating === 0} className="w-full py-5 bg-[var(--red)] text-white rounded-full font-black text-[11px] uppercase tracking-widest shadow-lg active:scale-95 transition-all">{isSubmittingReview ? "Envoi..." : (editingReview ? "Mettre à jour" : "Publier mon avis")}</button>
               </form>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </div>
  );
}
