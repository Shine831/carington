"use client";

import { useEffect, useState, useCallback } from "react";
import { useRouter } from "next/navigation";
import { Users, Briefcase, FileText, BarChart, Bell, Search, AlertTriangle, Clock, CheckCircle, Shield, Mail, LogOut, Eye, EyeOff, Trash2, Edit3, X, ArrowRight, Phone, Star, Lock, Key, ShieldAlert, Activity, Filter, RefreshCw } from "lucide-react";
import { motion, AnimatePresence } from "framer-motion";
import { FadeUp, StaggerContainer, StaggerItem } from "@/components/ui/Motion";
import { AuraGradient } from "@/components/ui/AuraGradient";
import { useI18n } from "@/context/LanguageContext";
import { useAuth } from "@/hooks/useAuth";
import { getServices, getBookings, getUsers, getMessages, getReviews, updateBookingStatus, updateMessageStatus, updateService, deleteBooking, deleteService, createService, deleteReview, deleteUserDoc, BookingData, getUserById, setUserPin, markAllReviewsAsRead, updateUserDoc } from "@/lib/firebase/db";
import { logoutUser } from "@/lib/firebase/auth";
import { EmailAuthProvider, reauthenticateWithCredential, updatePassword } from "firebase/auth";
import { auth } from "@/lib/firebase/config";

const STATUS_MAP = {
  fr: {
    PENDING:   { label: "En attente", cls: "bg-amber-500/10 text-amber-500 border-amber-500/20" },
    ACTIVE:    { label: "En cours",   cls: "bg-blue-500/10 text-blue-500 border-blue-500/20" },
    COMPLETED: { label: "Terminé",    cls: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" },
    REJECTED:  { label: "Rejeté",     cls: "bg-red-500/10 text-red-500 border-red-500/20" },
    UNREAD:    { label: "Non lu",     cls: "bg-red-500/10 text-red-500 border-red-500/20" },
    READ:      { label: "Lu",         cls: "bg-slate-500/10 text-slate-400 border-slate-500/20" },
    REPLIED:   { label: "Répondu",    cls: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" }
  },
  en: {
    PENDING:   { label: "Pending", cls: "bg-amber-500/10 text-amber-500 border-amber-500/20" },
    ACTIVE:    { label: "Active",   cls: "bg-blue-500/10 text-blue-500 border-blue-500/20" },
    COMPLETED: { label: "Completed",    cls: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" },
    REJECTED:  { label: "Rejected",     cls: "bg-red-500/10 text-red-500 border-red-500/20" },
    UNREAD:    { label: "Unread",     cls: "bg-red-500/10 text-red-500 border-red-500/20" },
    READ:      { label: "Read",         cls: "bg-slate-500/10 text-slate-400 border-slate-500/20" },
    REPLIED:   { label: "Replied",    cls: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" }
  }
};

export default function AdminDashboard() {
  const { t, language } = useI18n();
  const router = useRouter();
  const { user, role, loading: authLoading } = useAuth();

  const [activeTab, setActiveTab] = useState("requests");
  const [searchTerm, setSearchTerm] = useState("");
  const [data, setData] = useState<{ requests: any[], clients: any[], services: any[], messages: any[], reviews: any[] }>({
    requests: [],
    clients: [],
    services: [],
    messages: [],
    reviews: []
  });
  const [loading, setLoading] = useState(true);
  const [showNotifications, setShowNotifications] = useState(false);

  const [selectedBooking, setSelectedBooking] = useState<any | null>(null);
  const [selectedMessage, setSelectedMessage] = useState<any | null>(null);
  const [statusPrompt, setStatusPrompt] = useState<{ id: string, status: string } | null>(null);
  const [adminNote, setAdminNote] = useState("");
  const [newServiceModal, setNewServiceModal] = useState(false);
  const [newServiceForm, setNewServiceForm] = useState({ title: "", description: "", priceCFA: 0, category: "IT" });

  const [checkingPin, setCheckingPin] = useState(true);
  const [hasPinConfigured, setHasPinConfigured] = useState(false);
  const [isPinVerified, setIsPinVerified] = useState(false);
  const [pinInput, setPinInput] = useState("");
  const [pinError, setPinError] = useState(false);

  // Security Modals
  const [showPinChangeModal, setShowPinChangeModal] = useState(false);
  const [pinChangeForm, setPinChangeForm] = useState({ oldPin: "", newPin: "", error: "", success: "" });
  const [isChangingPin, setIsChangingPin] = useState(false);
  const [showOldPin, setShowOldPin] = useState(false);
  const [showNewPin, setShowNewPin] = useState(false);

  const [showPasswordChangeModal, setShowPasswordChangeModal] = useState(false);
  const [passwordChangeForm, setPasswordChangeForm] = useState({ oldPassword: "", newPassword: "", error: "", success: "" });
  const [isChangingPassword, setIsChangingPassword] = useState(false);
  const [showOldPassword, setShowOldPassword] = useState(false);
  const [showNewPassword, setShowNewPassword] = useState(false);

  // Profile State
  const [profileForm, setProfileForm] = useState({ name: "", email: "", currentPassword: "", error: "", success: "" });
  const [isUpdatingProfile, setIsUpdatingProfile] = useState(false);

  const friendlyFirebaseError = (code: string | undefined, fallback?: string): string => {
    const map: Record<string, string> = {
      "auth/wrong-password": "Mot de passe actuel incorrect.",
      "auth/invalid-credential": "Identifiants incorrects. Veuillez réessayer.",
      "auth/requires-recent-login": "Session expirée. Déconnectez-vous et reconnectez-vous.",
      "auth/email-already-in-use": "Email déjà utilisé.",
      "auth/weak-password": "Mot de passe trop faible.",
    };
    return map[code || ""] || fallback || "Une erreur s'est produite.";
  };

  useEffect(() => {
    if (!authLoading) {
      if (!user) { router.push("/account"); return; }
      if (role !== "ADMIN") { router.push("/dashboard"); return; }

      if (typeof window !== "undefined" && sessionStorage.getItem("admin_pin_verified") === "true") {
        setIsPinVerified(true);
        setCheckingPin(false);
        return;
      }

      getUserById(user.uid).then(userData => {
        if (userData && userData.pin) setHasPinConfigured(true);
        else setHasPinConfigured(false);
        setProfileForm({ name: user.displayName || "Admin", email: user.email || "", currentPassword: "", error: "", success: "" });
        setCheckingPin(false);
      });
    }
  }, [user, role, authLoading, router]);

  async function hashPin(pin: string) {
    const enc = new TextEncoder().encode(pin);
    const hashBuffer = await crypto.subtle.digest('SHA-256', enc);
    return Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  const fetchData = useCallback(async () => {
    if (role !== "ADMIN") return;
    setLoading(true);
    try {
      const [reqs, clis, srvs, msgs, revs] = await Promise.all([
        getBookings(), getUsers(), getServices(), getMessages(), getReviews()
      ]);

      const userMap: Record<string, { email?: string; displayName?: string }> = {};
      clis.forEach((u: any) => { userMap[u.id] = { email: u.email, displayName: u.displayName }; });

      const enrichedReqs = reqs.map((req: any) => {
        const fresh = req.userId ? userMap[req.userId] : null;
        return { ...req, email: fresh?.email || req.email, clientName: fresh?.displayName || req.entity };
      });

      const enrichedRevs = revs.map((rev: any) => {
        const fresh = rev.userId ? userMap[rev.userId] : null;
        return { ...rev, authorName: fresh?.displayName || rev.authorName };
      });

      setData({ requests: enrichedReqs, clients: clis, services: srvs, messages: msgs, reviews: enrichedRevs });
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  }, [role]);

  useEffect(() => { fetchData(); }, [fetchData]);

  useEffect(() => {
    if (activeTab === "reviews") {
      markAllReviewsAsRead().then(() => {
        setData(prev => ({ ...prev, reviews: prev.reviews.map(r => ({ ...r, isRead: true })) }));
      });
    }
  }, [activeTab]);

  const handleLogout = async () => {
    if (!confirm(language === "fr" ? "Déconnexion ?" : "Log out?")) return;
    sessionStorage.removeItem("admin_pin_verified");
    await logoutUser();
    router.push("/");
  };

  const attemptStatusChange = (id: string, newStatus: string) => {
    setStatusPrompt({ id, status: newStatus });
    setAdminNote("");
  };

  const confirmStatusChange = async () => {
    if (!statusPrompt) return;
    await updateBookingStatus(statusPrompt.id, statusPrompt.status, adminNote);
    setStatusPrompt(null);
    setAdminNote("");
    fetchData();
  };

  const handleUpdateMessage = async (id: string, status: any) => {
    await updateMessageStatus(id, status);
    fetchData();
  };

  const handleDeleteBooking = async (id: string) => {
    if (confirm("Supprimer définitivement ?")) { await deleteBooking(id); fetchData(); }
  };

  const handleCreateService = async (e: React.FormEvent) => {
    e.preventDefault();
    await createService(newServiceForm);
    setNewServiceModal(false);
    fetchData();
  };

  const [editServiceModal, setEditServiceModal] = useState<any | null>(null);

  const handleUpdateService = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!editServiceModal) return;
    const { id, title, description, priceCFA, category } = editServiceModal;
    await updateService(id, { title, description, priceCFA, category });
    setEditServiceModal(null);
    fetchData();
  };

  const handleDeleteService = async (id: string) => {
    if (confirm("Supprimer ce service ?")) { await deleteService(id); fetchData(); }
  };

  const handlePinChangeSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!user) return;
    setPinChangeForm(p => ({ ...p, error: "", success: "" }));
    setIsChangingPin(true);
    try {
      const userData = await getUserById(user.uid);
      if (!userData) throw new Error("Erreur serveur.");
      const oldHashed = await hashPin(pinChangeForm.oldPin);
      if (oldHashed !== userData.pin) throw new Error("Ancien PIN incorrect.");
      if (pinChangeForm.newPin.length !== 6) throw new Error("Le PIN doit faire 6 chiffres.");
      const newHashed = await hashPin(pinChangeForm.newPin);
      await setUserPin(user.uid, newHashed);
      setPinChangeForm({ oldPin: "", newPin: "", error: "", success: "PIN modifié !" });
      setTimeout(() => setShowPinChangeModal(false), 2000);
    } catch (err: any) {
      setPinChangeForm(p => ({ ...p, error: err.message }));
    } finally { setIsChangingPin(false); }
  };

  const handleProfileUpdate = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!user) return;
    setIsUpdatingProfile(true);
    try {
      const { updateProfile: fbUpdateProfile, updateEmail: fbUpdateEmail } = await import("firebase/auth");
      if (profileForm.name !== user.displayName) {
        await fbUpdateProfile(user, { displayName: profileForm.name });
        await updateUserDoc(user.uid, { displayName: profileForm.name });
      }
      setProfileForm(p => ({ ...p, success: "Profil mis à jour !" }));
    } catch (err: any) {
      setProfileForm(p => ({ ...p, error: err.message }));
    } finally { setIsUpdatingProfile(false); }
  };

  const handleDeleteClient = async (uid: string) => {
    if (confirm("Supprimer ce compte client ?")) {
      try { await deleteUserDoc(uid); fetchData(); }
      catch (err) { alert("Erreur."); }
    }
  };

  const handleDeleteReview = async (id: string) => {
    if (confirm("Supprimer ce témoignage ?")) { await deleteReview(id); fetchData(); }
  };

  if (authLoading || role !== "ADMIN" || checkingPin) {
    return (
      <div className="min-h-screen bg-[var(--off-white)] flex flex-col items-center justify-center">
        <div className="w-12 h-12 rounded-2xl flex items-center justify-center border border-red-100 bg-[var(--red-light)] mb-6 shadow-sm"><Shield className="w-6 h-6 text-[var(--red)] animate-pulse" /></div>
      </div>
    );
  }

  if (!isPinVerified) {
    const handlePinSubmit = async (e: React.FormEvent) => {
      e.preventDefault();
      if (!user || pinInput.length < 4) return;
      const hashed = await hashPin(pinInput);
      if (!hasPinConfigured) {
        await setUserPin(user.uid, hashed);
        setHasPinConfigured(true);
        setIsPinVerified(true);
        sessionStorage.setItem("admin_pin_verified", "true");
        fetchData();
      } else {
        const userData = await getUserById(user.uid);
        if (userData?.pin === hashed) {
          setIsPinVerified(true);
          sessionStorage.setItem("admin_pin_verified", "true");
          fetchData();
        } else {
          setPinError(true);
          setPinInput("");
        }
      }
    };

    return (
      <div className="min-h-[100svh] bg-[var(--off-white)] flex flex-col items-center justify-center p-4 relative overflow-hidden">
        <AuraGradient color="var(--red)" className="w-[800px] h-[800px] opacity-[0.03]" />
        <motion.div initial={{ opacity: 0, scale: 0.98 }} animate={{ opacity: 1, scale: 1 }} className="w-full max-w-sm relative z-10">
          <div className="bg-white/80 backdrop-blur-3xl border border-[var(--border)] p-10 rounded-[2.5rem] shadow-xl flex flex-col items-center text-center">
            <div className="w-16 h-16 rounded-2xl bg-[var(--red-light)] text-[var(--red)] flex items-center justify-center mb-6 border border-red-100 shadow-sm"><Lock className="w-8 h-8" /></div>
            <h1 className="text-2xl font-black text-[var(--charcoal)] tracking-tight mb-2">{hasPinConfigured ? "Accès Restreint" : "Initier Code Admin"}</h1>
            <p className="text-[var(--slate)] text-[11px] mb-8 leading-relaxed">Veuillez entrer le Code PIN Maître pour débloquer l{"'"}interface.</p>
            <form onSubmit={handlePinSubmit} className="w-full space-y-6">
              <input type="password" value={pinInput} onChange={(e) => { setPinInput(e.target.value); setPinError(false); }} placeholder="••••" maxLength={6} autoFocus className={`w-full bg-[var(--off-white)] border ${pinError ? "border-red-500" : "border-[var(--border)] focus:border-[var(--red)]"} p-4 rounded-2xl text-center text-2xl font-black tracking-[1em] outline-none transition-all`} />
              <button type="submit" disabled={pinInput.length < 4} className="w-full py-4 bg-[var(--red)] rounded-2xl text-white font-black text-[11px] uppercase tracking-widest shadow-lg disabled:opacity-50 transition-all">{hasPinConfigured ? "Déverrouiller" : "Enregistrer mon PIN"}</button>
            </form>
            <button onClick={handleLogout} className="mt-8 text-[10px] text-[var(--muted)] hover:text-red-500 font-black uppercase tracking-widest transition-colors">Déconnexion</button>
          </div>
        </motion.div>
      </div>
    );
  }

  const langKey = language as "fr" | "en";
  const NAV = [
    { id: "requests", label: t.admin.nav.requests, icon: Briefcase },
    { id: "clients", label: t.admin.nav.clients, icon: Users },
    { id: "messages", label: t.admin.nav.messages, icon: Mail },
    { id: "reviews", label: t.admin.nav.testimonials, icon: Star, badge: (data.reviews || []).filter(r => r.isRead === false).length || 0 },
    { id: "services", label: t.admin.nav.catalog, icon: Search },
    { id: "profile", label: t.admin.nav.settings, icon: BarChart },
  ];
  const STATS = [
    { label: t.admin.stats.pending, val: data.requests.filter(r => r.status === "PENDING").length, icon: Clock, color: "text-amber-500", bg: "bg-amber-500/10", border: "border-amber-500/20" },
    { label: t.admin.stats.active, val: data.requests.filter(r => r.status === "ACTIVE").length, icon: Activity, color: "text-blue-500", bg: "bg-blue-500/10", border: "border-blue-500/20" },
    { label: t.admin.stats.completed, val: data.requests.filter(r => r.status === "COMPLETED").length, icon: CheckCircle, color: "text-emerald-500", bg: "bg-emerald-500/10", border: "border-emerald-500/20" },
    { label: t.admin.stats.users, val: data.clients.length, icon: Users, color: "text-[var(--red)]", bg: "bg-[var(--red)]/10", border: "border-[var(--red)]/20" }
  ];

  const filteredData = (activeTab === "requests" ? data.requests :
                       activeTab === "messages" ? data.messages :
                       activeTab === "clients" ? data.clients :
                       activeTab === "services" ? data.services :
                       activeTab === "reviews" ? data.reviews : []).filter((item: any) => {
    const search = searchTerm.toLowerCase();
    return (item.clientName?.toLowerCase().includes(search) ||
            item.entity?.toLowerCase().includes(search) ||
            item.email?.toLowerCase().includes(search) ||
            item.name?.toLowerCase().includes(search) ||
            item.title?.toLowerCase().includes(search) ||
            item.subject?.toLowerCase().includes(search));
  });

  return (
    <div className="min-h-[100svh] bg-[var(--off-white)] flex pt-0 relative overflow-x-hidden text-[var(--charcoal)] font-sans pb-20 md:pb-0">
      <AuraGradient color="var(--red)" className="top-[-10%] right-[-10%] w-[600px] h-[600px] opacity-[0.03]" />

      {/* Sidebar */}
      <motion.aside className="w-64 xl:w-72 glass-morphism flex flex-col fixed top-0 bottom-0 left-0 z-40 hidden md:flex border-r border-slate-200/50 shadow-xl">
        <div className="p-8 border-b border-slate-100/50">
          <div className="flex items-center gap-4">
            <div className="w-12 h-12 rounded-2xl bg-[var(--red)] border border-[var(--red)] flex items-center justify-center shadow-[var(--shadow-red)] relative overflow-hidden group">
              <Shield className="w-6 h-6 text-white relative z-10" />
              <motion.div animate={{ rotate: 360 }} transition={{ duration: 10, repeat: Infinity, ease: "linear" }} className="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100" />
            </div>
            <div>
              <p className="text-[10px] font-black text-[var(--muted)] uppercase tracking-[0.3em]">{t.admin.tag}</p>
              <p className="font-black text-[var(--charcoal)] text-sm tracking-tight flex items-center gap-2"><span className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" />SESSION ACTIVE</p>
            </div>
          </div>
        </div>
        <nav className="flex-1 p-4 space-y-1.5 mt-4 custom-scrollbar overflow-y-auto">
          {NAV.map(({ id, label, icon: Icon, badge }) => (
            <button key={id} onClick={() => { setActiveTab(id); setSearchTerm(""); }} className={`w-full flex items-center justify-between px-5 py-4 rounded-2xl text-[10px] font-black uppercase tracking-[0.15em] transition-all duration-500 relative group overflow-hidden ${activeTab === id ? "text-white" : "text-[var(--muted)] hover:text-[var(--charcoal)] hover:bg-white"}`}>
              {activeTab === id && <motion.div layoutId="adminNavGlow" className="absolute inset-0 bg-[var(--charcoal)] -z-10" />}
              <span className="flex items-center gap-4 relative z-10"><Icon className={`w-4 h-4 ${activeTab === id ? "text-[var(--red)]" : ""}`} />{label}</span>
              {badge && badge > 0 && <span className={`px-2.5 py-1 rounded-full text-[9px] font-black relative z-10 ${activeTab === id ? "bg-[var(--red)] text-white" : "bg-red-50 text-[var(--red)]"}`}>{badge}</span>}
            </button>
          ))}
        </nav>
        <div className="p-6 border-t border-slate-100">
          <button onClick={handleLogout} className="w-full flex items-center gap-4 px-5 py-4 text-[10px] font-black uppercase tracking-widest text-red-500 hover:bg-red-50 hover:text-[var(--red)] rounded-xl transition-all"><LogOut className="w-4 h-4" /> Déconnexion</button>
        </div>
      </motion.aside>

      {/* Main Content */}
      <main className="flex-1 md:ml-64 xl:ml-72 flex flex-col min-h-[100svh] relative z-20">
        <header className="glass-morphism px-8 py-5 flex items-center justify-between sticky top-0 z-50 border-b border-slate-200/50 shadow-sm">
          <div className="flex-1 max-w-md relative hidden sm:block">
            <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--muted)]" />
            <input type="text" value={searchTerm} onChange={(e) => setSearchTerm(e.target.value)} placeholder="Rechercher..." className="w-full pl-11 pr-4 py-2.5 bg-[var(--off-white)] border border-slate-200 rounded-full text-xs font-bold focus:border-[var(--red)] outline-none transition-all" />
          </div>
          <div className="flex items-center gap-6">
            <button onClick={() => fetchData()} title="Actualiser" className="p-2.5 rounded-full bg-[var(--red-light)] text-[var(--red)] hover:bg-[var(--red)] hover:text-white transition-all"><RefreshCw className={`w-4 h-4 ${loading ? 'animate-spin' : ''}`} /></button>
            <button onClick={() => setShowPinChangeModal(true)} className="p-2.5 bg-emerald-50 text-emerald-600 rounded-full hover:bg-emerald-100"><Key className="w-4 h-4" /></button>
            <button onClick={() => setShowNotifications(!showNotifications)} className="relative p-2.5 bg-[var(--off-white)] border border-slate-200 rounded-full"><Bell className="w-4 h-4 text-[var(--slate)]" />{(data.reviews.filter(r=>!r.isRead).length + data.messages.filter(m=>m.status==='UNREAD').length) > 0 && <span className="absolute top-2 right-2 w-2 h-2 bg-[var(--red)] rounded-full border-2 border-white" />}</button>
            <div className="w-10 h-10 rounded-full bg-[var(--red)] text-white flex items-center justify-center font-black text-xs border-2 border-white shadow-md">SA</div>
          </div>
        </header>

        <div className="p-8 lg:p-12 flex-1 w-full overflow-x-hidden">
          <StaggerContainer className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
            {STATS.map(({ label, val, icon: Icon, color, bg, border }) => (
              <StaggerItem key={label}>
                <div className="relative group overflow-hidden rounded-[2.5rem] p-8 border border-white/60 bg-white/70 backdrop-blur-xl shadow-xl transition-all duration-700 hover:shadow-2xl">
                  <div className="relative z-10">
                    <div className="flex items-center justify-between mb-8">
                      <div className={`w-12 h-12 rounded-2xl flex items-center justify-center border ${bg} ${border} shadow-sm group-hover:scale-110 transition-transform duration-500`}><Icon className={`w-6 h-6 ${color}`} /></div>
                      <div className="h-1 w-12 bg-slate-100 rounded-full overflow-hidden"><motion.div initial={{ width: 0 }} animate={{ width: "70%" }} transition={{ duration: 1.5 }} className={`h-full ${color.replace("text-", "bg-")}`} /></div>
                    </div>
                    <p className="text-[10px] font-black text-[var(--muted)] uppercase tracking-[0.25em] mb-2">{label}</p>
                    <div className="flex items-baseline gap-2"><motion.span initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} className={`text-5xl font-black ${color} tracking-tighter leading-none italic`}>{val}</motion.span></div>
                  </div>
                  <AuraGradient color={color.includes("red") ? "var(--red)" : color.replace("text-", "").replace("-500", "")} className="w-32 h-32 -bottom-10 -right-10 opacity-[0.03] group-hover:opacity-[0.1]" />
                </div>
              </StaggerItem>
            ))}
          </StaggerContainer>

          <div className="flex items-center justify-between gap-4 mb-10">
            <h2 className="text-2xl font-black text-[var(--charcoal)] tracking-tight uppercase">Base de données: {activeTab}</h2>
            {activeTab === "services" && <button onClick={() => setNewServiceModal(true)} className="btn btn-red px-6 py-3 text-[10px] uppercase font-black">+ Nouveau Service</button>}
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {activeTab === "requests" && filteredData.map((req) => {
              const mapObj = STATUS_MAP[langKey][req.status as keyof typeof STATUS_MAP["fr"]] || STATUS_MAP[langKey].PENDING;
              return (
                <motion.div key={req.id} whileHover={{ y: -5 }} className="bento-item glass-morphism spatial-ui-layer p-8 group relative overflow-hidden">
                  <div className="absolute top-0 left-0 w-full h-1 bg-[var(--red)]" style={{ backgroundColor: req.status === "COMPLETED" ? "#10B981" : req.status === "ACTIVE" ? "#3B82F6" : "var(--red)" }} />
                  <div className="space-y-6">
                    <div className="flex justify-between items-start">
                      <div className="space-y-1">
                        <p className="text-[10px] font-black text-[var(--muted)] uppercase tracking-widest">{req.createdAt ? new Date(req.createdAt.seconds*1000).toLocaleDateString() : 'N/A'}</p>
                        <h3 className="text-xl font-black text-[var(--charcoal)] group-hover:text-[var(--red)] transition-colors line-clamp-1">{req.clientName || req.entity}</h3>
                      </div>
                      <span className={`px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border shadow-sm ${mapObj.cls}`}>{mapObj.label}</span>
                    </div>
                    <div className="p-5 bg-[var(--off-white)] rounded-2xl border border-slate-100 space-y-3">
                      <div><p className="text-[8px] font-black uppercase text-[var(--muted)] tracking-widest">Service</p><p className="text-xs font-bold text-[var(--charcoal)] truncate uppercase">{req.serviceId}</p></div>
                      <div><p className="text-[8px] font-black uppercase text-[var(--muted)] tracking-widest">Budget</p><p className="text-sm font-black text-[var(--red)] italic">{req.budget}</p></div>
                    </div>
                    <div className="flex items-center justify-between pt-4 border-t border-slate-100">
                      <button onClick={() => setSelectedBooking(req)} className="flex-[1.5] py-3 bg-[var(--charcoal)] text-white rounded-full text-[9px] font-black uppercase tracking-widest flex items-center justify-center gap-2 hover:bg-black transition-all shadow-md"><Eye className="w-3.5 h-3.5" /> Détails</button>
                      <button onClick={() => handleDeleteBooking(req.id)} className="ml-2 p-3 bg-red-50 text-red-500 rounded-full hover:bg-red-100 transition-all"><Trash2 className="w-4 h-4" /></button>
                    </div>
                  </div>
                </motion.div>
              );
            })}

            {activeTab === "messages" && filteredData.map((msg) => {
              const mapObj = STATUS_MAP[langKey][msg.status as keyof typeof STATUS_MAP["fr"]] || STATUS_MAP[langKey].UNREAD;
              return (
                <motion.div key={msg.id} whileHover={{ y: -5 }} className="bento-item glass-morphism p-8 group relative overflow-hidden">
                  <div className={`absolute top-0 left-0 w-full h-1 ${msg.status === 'UNREAD' ? 'bg-red-500' : 'bg-slate-300'}`} />
                  <div className="space-y-5">
                    <div className="flex justify-between items-start">
                      <div className="space-y-1">
                        <p className="text-[10px] font-black text-[var(--muted)] uppercase">{msg.createdAt ? new Date(msg.createdAt.seconds*1000).toLocaleDateString() : 'N/A'}</p>
                        <h3 className="text-lg font-black text-[var(--charcoal)]">{msg.name}</h3>
                        <p className="text-[10px] font-bold text-[var(--red)]">{msg.email}</p>
                      </div>
                      <span className={`px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border shadow-sm ${mapObj.cls}`}>{mapObj.label}</span>
                    </div>
                    <p className="text-xs text-[var(--slate)] font-medium leading-relaxed p-4 bg-[var(--off-white)] rounded-2xl border border-slate-100 italic line-clamp-3">"{msg.message}"</p>
                    <div className="flex gap-2">
                      <button onClick={() => setSelectedMessage(msg)} className="flex-1 py-3 bg-[var(--red)] text-white rounded-full text-[9px] font-black uppercase tracking-widest shadow-md">Lire</button>
                      <button onClick={() => handleUpdateMessage(msg.id, "READ")} className="flex-1 py-3 bg-white border border-slate-200 text-[var(--charcoal)] rounded-full text-[9px] font-black uppercase tracking-widest">Marquer Lu</button>
                    </div>
                  </div>
                </motion.div>
              );
            })}

            {activeTab === "clients" && filteredData.map((cli) => (
              <motion.div key={cli.id} whileHover={{ y: -5 }} className="bento-item glass-morphism p-8 group relative overflow-hidden">
                <div className={`absolute top-0 left-0 w-full h-1 ${cli.role === 'ADMIN' ? 'bg-[var(--red)]' : 'bg-blue-500'}`} />
                <div className="space-y-6">
                  <div className="flex justify-between items-center">
                    <div className="w-12 h-12 rounded-full bg-[var(--off-white)] border border-slate-200 flex items-center justify-center text-lg font-black text-[var(--muted)]">{(cli.displayName || "C")[0]}</div>
                    <span className={`px-3 py-1 rounded-full text-[9px] font-black uppercase border shadow-sm ${cli.role === 'ADMIN' ? 'bg-red-50 text-[var(--red)] border-red-100' : 'bg-blue-50 text-blue-600 border-blue-100'}`}>{cli.role || "CLIENT"}</span>
                  </div>
                  <div>
                    <h3 className="text-lg font-black text-[var(--charcoal)]">{cli.displayName || "Client"}</h3>
                    <p className="text-xs font-bold text-[var(--slate)]">{cli.email}</p>
                  </div>
                  <div className="flex items-center justify-between pt-4 border-t border-slate-100">
                    <p className="text-[8px] font-black text-[var(--muted)] uppercase tracking-widest">UID: {cli.uid.substring(0, 10)}...</p>
                    {cli.role !== 'ADMIN' && <button onClick={() => handleDeleteClient(cli.uid)} className="p-2.5 bg-red-50 text-red-500 rounded-full hover:bg-red-100 transition-all"><Trash2 className="w-4 h-4" /></button>}
                  </div>
                </div>
              </motion.div>
            ))}

            {activeTab === "services" && filteredData.map((srv) => (
              <motion.div key={srv.id} whileHover={{ y: -5 }} className="bento-item glass-morphism p-8 group relative overflow-hidden">
                <div className="absolute top-0 left-0 w-full h-1 bg-emerald-500" />
                <div className="space-y-5">
                  <div className="flex justify-between items-start">
                    <span className="px-3 py-1 rounded-full bg-emerald-50 text-emerald-600 text-[9px] font-black uppercase border border-emerald-100 shadow-sm">{srv.category || "General"}</span>
                    <span className="text-sm font-black text-emerald-600 italic tracking-tighter">{srv.priceCFA} CFA</span>
                  </div>
                  <h3 className="text-lg font-black text-[var(--charcoal)] uppercase leading-tight line-clamp-2">{srv.title}</h3>
                  <p className="text-xs text-[var(--slate)] leading-relaxed line-clamp-3 p-4 bg-[var(--off-white)] rounded-2xl border border-slate-100">{srv.description}</p>
                  <div className="flex gap-2">
                    <button onClick={() => setEditServiceModal(srv)} className="flex-1 py-3 bg-[var(--charcoal)] text-white rounded-full text-[9px] font-black uppercase tracking-widest shadow-md">Éditer</button>
                    <button onClick={() => handleDeleteService(srv.id)} className="p-3 bg-red-50 text-red-500 rounded-full hover:bg-red-100 transition-all"><Trash2 className="w-4 h-4" /></button>
                  </div>
                </div>
              </motion.div>
            ))}

            {activeTab === "reviews" && filteredData.map((rev) => (
              <motion.div key={rev.id} whileHover={{ y: -5 }} className="bento-item glass-morphism p-8 group relative overflow-hidden">
                <div className="absolute top-0 left-0 w-full h-1 bg-amber-400" />
                <div className="space-y-5">
                  <div className="flex justify-between items-start">
                    <div className="flex gap-0.5">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <Star key={i} className={`w-3 h-3 ${i < rev.rating ? "fill-amber-400 text-amber-400" : "fill-slate-100 text-slate-200"}`} />
                      ))}
                    </div>
                    <p className="text-[9px] font-black text-[var(--muted)] uppercase">{rev.createdAt ? new Date(rev.createdAt.seconds*1000).toLocaleDateString() : 'N/A'}</p>
                  </div>
                  <p className="text-xs text-[var(--slate)] font-medium italic line-clamp-4 leading-relaxed p-4 bg-[var(--off-white)] rounded-2xl border border-slate-100">"{rev.comment}"</p>
                  <div className="flex items-center justify-between pt-4 border-t border-slate-100">
                    <div>
                      <p className="text-[10px] font-black text-[var(--charcoal)]">{rev.authorName || "Client"}</p>
                      <p className="text-[8px] font-black uppercase text-amber-500">{rev.serviceId || "Général"}</p>
                    </div>
                    <button onClick={() => handleDeleteReview(rev.id)} className="p-2.5 bg-red-50 text-red-500 rounded-full hover:bg-red-100 transition-all"><Trash2 className="w-4 h-4" /></button>
                  </div>
                </div>
              </motion.div>
            ))}

            {filteredData.length === 0 && !loading && (
              <div className="col-span-full py-32 text-center rounded-[3rem] border border-dashed border-slate-200 bg-white/50 backdrop-blur-md">
                <div className="w-20 h-20 rounded-full bg-[var(--off-white)] flex items-center justify-center mx-auto mb-6 shadow-inner"><Search className="w-10 h-10 text-[var(--muted)]" /></div>
                <p className="text-[var(--muted)] font-black uppercase tracking-[0.3em] text-xs">Aucun résultat trouvé.</p>
              </div>
            )}
          </div>

          {activeTab === "profile" && (
            <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className="grid grid-cols-1 lg:grid-cols-3 gap-8">
              <div className="p-10 bg-white border border-[var(--border)] rounded-[3rem] flex flex-col items-center text-center shadow-lg relative overflow-hidden">
                <AuraGradient color="var(--red)" className="top-0 left-0 w-32 h-32 opacity-[0.05]" />
                <div className="w-24 h-24 rounded-full bg-[var(--red-light)] flex items-center justify-center text-3xl font-black text-[var(--red)] mb-6 shadow-md border border-red-100">{(user?.displayName || "A")[0]}</div>
                <h3 className="text-2xl font-black text-[var(--charcoal)] tracking-tight">{user?.displayName || "Administrateur"}</h3>
                <p className="text-[10px] font-black uppercase text-emerald-600 tracking-widest mt-2">Accès Super-Privilégié</p>
                <div className="mt-10 pt-10 border-t border-slate-100 w-full space-y-4 text-left">
                  <div className="flex items-center justify-between"><span className="text-[10px] font-black text-[var(--muted)] uppercase">Version</span><span className="text-[10px] font-bold text-[var(--slate)]">V3.0.0-GOLD</span></div>
                  <button onClick={() => setShowPinChangeModal(true)} className="w-full py-4 px-6 bg-[var(--off-white)] rounded-2xl flex items-center justify-between text-[10px] font-black uppercase tracking-widest border border-slate-200 hover:border-[var(--red)] transition-all"><span>Code PIN Maître</span><Key className="w-4 h-4 text-emerald-600" /></button>
                </div>
              </div>
              <div className="lg:col-span-2 p-10 bg-white border border-[var(--border)] rounded-[3rem] shadow-lg relative overflow-hidden">
                <AuraGradient color="var(--red)" className="bottom-[-10%] right-[-10%] w-64 h-64 opacity-[0.03]" />
                <h3 className="text-2xl font-black text-[var(--charcoal)] tracking-tighter mb-8 flex items-center gap-4"><div className="w-10 h-10 rounded-2xl bg-emerald-50 flex items-center justify-center"><Edit3 className="w-5 h-5 text-emerald-600" /></div>Paramètres</h3>
                <form onSubmit={handleProfileUpdate} className="space-y-8">
                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <div className="space-y-2"><label className="text-[10px] font-black uppercase text-[var(--muted)] tracking-widest">Nom</label><input type="text" value={profileForm.name} onChange={e => setProfileForm({...profileForm, name: e.target.value})} className="w-full bg-[var(--off-white)] border border-slate-200 p-5 rounded-2xl text-sm font-bold focus:border-[var(--red)] outline-none" /></div>
                    <div className="space-y-2"><label className="text-[10px] font-black uppercase text-[var(--muted)] tracking-widest">Email</label><input type="email" value={profileForm.email} disabled className="w-full bg-slate-50 border border-slate-200 p-5 rounded-2xl text-sm font-bold opacity-60" /></div>
                  </div>
                  {profileForm.success && <p className="text-[10px] font-black text-emerald-600 uppercase">{profileForm.success}</p>}
                  <button type="submit" disabled={isUpdatingProfile} className="px-10 py-5 bg-[var(--charcoal)] text-white rounded-full font-black text-[11px] uppercase tracking-widest shadow-xl hover:scale-105 active:scale-95 transition-all">{isUpdatingProfile ? "Action..." : "Sauvegarder"}</button>
                </form>
              </div>
            </motion.div>
          )}
        </div>
      </main>

      {/* Modals */}
      <AnimatePresence>
        {selectedBooking && (
          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-xl">
            <div className="bg-white p-10 rounded-[3rem] border border-[var(--border)] w-full max-w-2xl relative shadow-2xl overflow-y-auto max-h-[90vh] custom-scrollbar">
              <button onClick={() => setSelectedBooking(null)} className="absolute top-6 right-6 p-2 text-[var(--muted)] hover:text-[var(--charcoal)]"><X className="w-6 h-6" /></button>
              <h2 className="text-2xl font-black text-[var(--charcoal)] uppercase tracking-tighter mb-8">Détails de la demande</h2>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-8 text-sm">
                <div><span className="text-[10px] font-black uppercase text-[var(--muted)] tracking-widest block mb-1">Client</span><p className="font-bold text-lg">{selectedBooking.clientName || selectedBooking.entity}</p></div>
                <div><span className="text-[10px] font-black uppercase text-[var(--muted)] tracking-widest block mb-1">Contact</span><p className="font-bold">{selectedBooking.email}<br/>{selectedBooking.phone}</p></div>
                <div><span className="text-[10px] font-black uppercase text-[var(--muted)] tracking-widest block mb-1">Service</span><p className="font-bold text-[var(--red)]">{selectedBooking.serviceId}</p></div>
                <div><span className="text-[10px] font-black uppercase text-[var(--muted)] tracking-widest block mb-1">Budget</span><p className="font-black text-emerald-600 italic text-lg">{selectedBooking.budget}</p></div>
                <div className="md:col-span-2"><span className="text-[10px] font-black uppercase text-[var(--muted)] tracking-widest block mb-2">Description</span><div className="p-6 bg-[var(--off-white)] border border-slate-100 rounded-3xl text-xs leading-relaxed whitespace-pre-wrap">{selectedBooking.description}</div></div>
              </div>
              <div className="mt-10 flex gap-4">
                 <div className="flex-1 relative">
                    <select value={selectedBooking.status} onChange={(e) => attemptStatusChange(selectedBooking.id, e.target.value)} className="w-full py-4 bg-[var(--off-white)] border border-slate-200 text-[10px] font-black uppercase text-center rounded-2xl outline-none focus:border-[var(--red)] appearance-none cursor-pointer">
                      <option value="PENDING">PENDING</option><option value="ACTIVE">ACTIVE</option><option value="COMPLETED">COMPLETED</option><option value="REJECTED">REJECTED</option>
                    </select>
                 </div>
                 <button onClick={() => { handleDeleteBooking(selectedBooking.id); setSelectedBooking(null); }} className="p-4 bg-red-50 text-red-500 rounded-2xl hover:bg-red-100 transition-all"><Trash2 className="w-5 h-5" /></button>
              </div>
            </div>
          </motion.div>
        )}

        {selectedMessage && (
          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-xl">
            <div className="bg-white p-10 rounded-[3rem] border border-[var(--border)] w-full max-w-2xl relative shadow-2xl">
              <button onClick={() => setSelectedMessage(null)} className="absolute top-6 right-6 p-2 text-[var(--muted)] hover:text-[var(--charcoal)]"><X className="w-6 h-6" /></button>
              <div className="flex items-center gap-4 mb-8"><div className="w-14 h-14 rounded-2xl bg-[var(--red-light)] text-[var(--red)] flex items-center justify-center shadow-sm"><Mail className="w-7 h-7" /></div><div><h2 className="text-xl font-black text-[var(--charcoal)] tracking-tight">{selectedMessage.subject}</h2><p className="text-[10px] font-black text-[var(--muted)] uppercase">{new Date(selectedMessage.createdAt.seconds*1000).toLocaleString()}</p></div></div>
              <div className="bg-[var(--off-white)] p-8 rounded-[2.5rem] border border-slate-200 mb-8 space-y-6">
                <div><span className="text-[10px] font-black uppercase text-[var(--muted)] block mb-1">Expéditeur</span><p className="font-bold">{selectedMessage.name} <span className="font-normal text-[var(--red)] ml-2">{selectedMessage.email}</span></p></div>
                <div><span className="text-[10px] font-black uppercase text-[var(--muted)] block mb-2">Message</span><p className="text-sm leading-relaxed whitespace-pre-wrap italic">"{selectedMessage.message}"</p></div>
              </div>
              <div className="flex justify-end gap-3">
                 <button onClick={() => { handleUpdateMessage(selectedMessage.id, "READ"); setSelectedMessage(null); }} className="px-6 py-3 bg-[var(--charcoal)] text-white rounded-full text-[10px] font-black uppercase tracking-widest shadow-md transition-all">Marquer Lu</button>
              </div>
            </div>
          </motion.div>
        )}

        {statusPrompt && (
          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-black/60 backdrop-blur-xl">
            <div className="bg-white p-10 rounded-[2.5rem] w-full max-w-md shadow-2xl border border-[var(--border)]">
              <h2 className="text-xl font-black text-[var(--charcoal)] uppercase mb-4">Mise à jour statut</h2>
              <p className="text-xs text-[var(--slate)] mb-6 font-medium">Passage à <strong className="text-[var(--red)]">{statusPrompt.status}</strong>. Note pour le client :</p>
              <textarea value={adminNote} onChange={(e) => setAdminNote(e.target.value)} placeholder="Votre commentaire..." className="w-full bg-[var(--off-white)] border border-slate-200 p-4 rounded-2xl text-sm h-32 resize-none outline-none focus:border-[var(--red)] mb-6 transition-all shadow-inner" />
              <div className="flex justify-end gap-3">
                <button onClick={() => setStatusPrompt(null)} className="px-6 py-3 bg-slate-100 rounded-full text-[10px] font-black uppercase tracking-widest">Annuler</button>
                <button onClick={confirmStatusChange} className="px-6 py-3 bg-[var(--red)] text-white rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg">Sauvegarder</button>
              </div>
            </div>
          </motion.div>
        )}

        {showPinChangeModal && (
          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-[120] flex items-center justify-center p-4 bg-black/60 backdrop-blur-md">
            <div className="bg-white p-10 rounded-[3rem] w-full max-w-sm relative shadow-2xl border border-[var(--border)] overflow-hidden">
              <AuraGradient color="emerald" className="top-0 right-0 w-64 h-64 opacity-[0.05]" />
              <button onClick={() => setShowPinChangeModal(false)} className="absolute top-6 right-6 p-2 text-[var(--muted)] hover:text-[var(--charcoal)]"><X className="w-5 h-5" /></button>
              <div className="mb-8"><div className="w-14 h-14 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-4"><Key className="w-7 h-7" /></div><h3 className="text-xl font-black text-[var(--charcoal)]">Code PIN Maître</h3><p className="text-[11px] font-medium text-[var(--slate)] mt-1">Ancien PIN + Nouveau PIN (6 chiffres).</p></div>
              <form onSubmit={handlePinChangeSubmit} className="space-y-6 relative z-10">
                <div className="space-y-4">
                  <input type="password" value={pinChangeForm.oldPin} onChange={e=>setPinChangeForm({...pinChangeForm, oldPin: e.target.value})} placeholder="Ancien PIN" maxLength={6} required className="w-full bg-[var(--off-white)] border border-slate-200 p-4 rounded-2xl text-center text-xl font-black tracking-widest outline-none focus:border-[var(--red)] transition-all shadow-inner" />
                  <input type="password" value={pinChangeForm.newPin} onChange={e=>setPinChangeForm({...pinChangeForm, newPin: e.target.value})} placeholder="Nouveau PIN" maxLength={6} required className="w-full bg-[var(--off-white)] border border-slate-200 p-4 rounded-2xl text-center text-xl font-black tracking-widest outline-none focus:border-[var(--red)] transition-all shadow-inner" />
                </div>
                {pinChangeForm.error && <p className="text-[10px] text-red-500 font-black uppercase text-center">{pinChangeForm.error}</p>}
                {pinChangeForm.success && <p className="text-[10px] text-emerald-600 font-black uppercase text-center">{pinChangeForm.success}</p>}
                <button type="submit" disabled={isChangingPin} className="w-full py-4 bg-emerald-500 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest shadow-xl hover:scale-105 active:scale-95 transition-all">{isChangingPin ? "Modification..." : "Confirmer"}</button>
              </form>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
