rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ─────────────────────────────────────
    // Is the user authenticated? (does NOT require email_verified — 
    // that check is enforced at the app level in useAuth.ts)
    function isSignedIn() {
      return request.auth != null;
    }

    // Is this user an ADMIN? Reads their Firestore role.
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // ─── USERS ────────────────────────────────────────────────
    // A user can always read their own document (needed for role-check during login,
    // even before email is verified — the app-level useAuth handles the verification gate).
    // Only admins can list all users.
    // No user can change their own role field.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();
    }

    // ─── SERVICES ─────────────────────────────────────────────
    // Services are publicly readable (homepage catalog).
    // Only admins can create, update, or delete services.
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── BOOKINGS (DEMANDES DE DEVIS) ─────────────────────────
    // Clients can create bookings with status PENDING.
    // Clients can only read & delete their OWN bookings (delete = cancel, PENDING only).
    // Only admins can update bookings (change status, add notes).
    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'PENDING';
      allow update: if isAdmin();
      allow delete: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING') ||
        isAdmin()
      );
    }

    // ─── MESSAGES (CONTACT) ───────────────────────────────────
    // Anyone can submit a contact message (public contact form).
    // Only admins can read, update, or delete messages.
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── REVIEWS (TÉMOIGNAGES) ────────────────────────────────
    // Restricted read: only authenticated users can query reviews.
    // Public visitors see curated showcase data (handled in app).
    // Any signed-in user can create a review (must use their own UID).
    // Only admins can delete reviews.
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

  }
}
