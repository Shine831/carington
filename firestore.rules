# Firebase Firestore Security Rules
# ============================================================
# IMPORTANT: Copy and paste these rules into your Firebase Console
# Firebase Console → Firestore Database → Rules
# ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: is the user logged in with a verified email?
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Helper function: retrieve the user's role from Firestore
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper function: is the user an ADMIN?
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'ADMIN';
    }

    // ─── USERS ───────────────────────────────────────────────
    // Users can only read their own document.
    // Admins can read all user documents.
    // No user can write another user's document directly.
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId && !('role' in request.resource.data);
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    // ─── SERVICES ────────────────────────────────────────────
    // All authenticated users can read services.
    // Only admins can create, update, or delete services.
    match /services/{serviceId} {
      allow read: if true; // Public read
      allow write: if isAdmin();
    }

    // ─── BOOKINGS (DEMANDES) ─────────────────────────────────
    // Clients can only read & create their own bookings.
    // Admins can read and update all bookings (status changes, notes).
    // Clients cannot update status themselves (only PENDING → cancel via delete).
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'PENDING';
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid && resource.data.status == 'PENDING'
      ) || isAdmin();
    }

    // ─── MESSAGES (CONTACT) ──────────────────────────────────
    // Anyone can create a contact message (public contact form).
    // Only admins can read, update, or delete messages.
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── REVIEWS (TÉMOIGNAGES) ───────────────────────────────
    // Authenticated + verified users can create reviews.
    // One review per user is NOT enforced here — handle in app logic.
    // Public read for the testimonials section.
    // Only admins can delete reviews.
    match /reviews/{reviewId} {
      allow read: if true; // Public
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

  }
}
